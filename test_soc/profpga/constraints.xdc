set_property BITSTREAM.GENERAL.COMPRESS TRUE          [current_design]
set_property BITSTREAM.CONFIG.UNUSEDPIN Pulldown      [current_design]
set_property CFGBVS GND                               [current_design]
set_property CONFIG_VOLTAGE 1.8                       [current_design]

set_property SEVERITY {Warning} [get_drc_checks NSTD-1]

#set_property CLOCK_DEDICATED_ROUTE BACKBONE [get_nets sys_clk_p_IBUF]
set_property -quiet PACKAGE_PIN BC28 [get_ports {sys_clk_n}]
set_property IOSTANDARD DIFF_SSTL12 [get_ports sys_clk_n]

set_property -quiet PACKAGE_PIN BC27 [get_ports {sys_clk_p}]
set_property IOSTANDARD DIFF_SSTL12 [get_ports sys_clk_p]


create_clock -add -name sys_clk_p_pin -period 5.00 -waveform {0 2.5} [get_ports {sys_clk_p}];

set_property DCI_CASCADE {41 43} [get_iobanks 42]

set_property CLOCK_DEDICATED_ROUTE BACKBONE [get_nets sys_clk_p]

